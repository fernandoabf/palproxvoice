# copia pra .env e preenche.  docker compose le isso sozinho.

# --- voice (local + vps) ---
VOICE_PASSWORD=test

# Porta HTTP no HOST. VPS: 8080. WSL2: 8088 (a 8080 costuma estar tomada pelo Windows).
HTTP_PORT=8080

# IP que o browser/audio usam pra te achar.
#   mesma maquina (WSL): teu IP de LAN (ex 192.168.x.x)
#   VPS: o IP publico da VPS
PUBLIC_IP=

# Nome + alcance (m) que o servidor manda pro companion ao conectar.
SERVER_NAME=PalProxVoice
VOICE_RANGE=50

# --- anti-spoof (V1.5) — DESLIGADO por padrao ---
# off    = confia na posicao do cliente (legado).
# verify = reconcilia com a REST do Palworld; spoof sustentado -> ignora a mentira.
# strict = posicao sempre da REST.
# verify/strict precisam ALCANCAR a REST do Palworld POR DENTRO da rede docker
# (a REST e' API de ADMIN -> NUNCA exponha publica). Ver docs/ANTI-SPOOF-DEPLOY.md.
PPV_AUTH_MODE=off
PPV_REST_URL=                 # ex.: http://palworld:8212 (ver docker-compose.palworld.example.yml)
PPV_REST_USER=admin
PPV_REST_PASS=                # = AdminPassword do servidor Palworld
PPV_POS_TOL_CM=5000           # tolerancia de divergencia (cm) ~50 m
PPV_DIVERGE_POLLS=4           # polls seguidos divergindo p/ agir
PPV_BAN=0                     # 1 = politica B (derruba + bloqueia no nivel da voz)

# --- V2 (EXPERIMENTAL) — posicao+yaw autoritativos do mod server-side (UE4SS) ---
# So liga se preencher PPV_PLAYERS_FILE (caminho do feed "fguid,x,y,z,yaw" que o mod
# escreve; voz e servidor de jogo compartilham o arquivo). Precisa de UE4SS no servidor
# (ver mod-server/). Tem prioridade sobre a REST. Deixe vazio pra usar so o verify/save.
PPV_PLAYERS_FILE=
PPV_FEED_POLL_MS=100
