# copia pra .env e preenche.  docker compose le isso sozinho.

# --- voice (local + vps) ---
VOICE_PASSWORD=test

# Porta HTTP no HOST. VPS: 8080. WSL2: 8088 (a 8080 costuma estar tomada pelo Windows).
HTTP_PORT=8080

# IP que o browser/audio usam pra te achar.
#   mesma maquina (WSL): teu IP de LAN (ex 192.168.2.57)
#   VPS: o IP publico (ex 69.62.88.69)
PUBLIC_IP=

# --- palworld de teste (so vps; local sobe mundo novo se vazio) ---
# usa as chaves R2 NOVAS (rotacionadas), nao as antigas.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
